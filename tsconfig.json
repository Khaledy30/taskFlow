{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@application/useCases/*": ["src/application/useCases/*"],
      "@application/repositories/*": ["src/application/repositories/*"],
      "@application/*": ["src/application/*"],
      "@domain/entities/*": ["src/domain/entities/*"],
      "@domain/utils/*": ["src/domain/utils/*"],
      "@infrastructure/database/*": ["src/infrastructure/database/*"],
      "@interface/controllers/*": ["src/interface/controllers/*"],
      "@routes/*": ["src/routes/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
